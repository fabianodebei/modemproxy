# Auto-generated by modemproxy for modem {{ name }} ({{ imei }}). DO NOT EDIT.
nserver {{ dns }}
nscache 65536
timeouts 1 5 30 60 180 1800 15 60
log /var/log/modemproxy/3proxy.{{ name }}.log D
logformat "- +_L%t.%. %N.%p %E %U %C:%c %R:%r %O %I %h %T"
rotate 7

{% if username %}
users {{ username }}:CL:{{ password }}
auth strong
allow {{ username }}
{% else %}
auth none
{% endif %}

# Bind outbound traffic to this modem's interface so each proxy egresses
# through its own SIM / public IP.
external {{ modem_ip }}
internal {{ bind_address }}

# HTTP/HTTPS proxy
proxy -p{{ http_port }} -i{{ bind_address }} -e{{ modem_ip }}

# SOCKS5 proxy
socks -p{{ socks_port }} -i{{ bind_address }} -e{{ modem_ip }}

flush
